  "keyFeatures": [
    "Type-safe tool definitions with Zod schema validation",
    "Multiple authentication strategies: OAuth 2.1 PKCE, Bearer token, API key, custom headers",
    "Cloudflare Workers and Node.js runtime support",
    "Built-in KV and in-memory storage backends with AES-256-GCM encryption",
    "Full MCP protocol support including SSE streaming and JSON-RPC",
    "Built-in echo and health check tools",
    "OAuth 2.1 with PKCE and dynamic client registration"
  ],
  "publicApiSurface": [
    "createMCPServer(options: MCPServerOptions): MCPServer",
    "defineTool(def: ToolDefinitionInput): SharedToolDefinition",
    "toolFail(defaults): (error: string) => T & { error: string }",
    "assertProviderToken(context: ToolContext): void",
    "KvTokenStore",
    "KvSessionStore",
    "MemoryTokenStore",
    "MemorySessionStore",
    "FileTokenStore",
    "SqliteSessionStore",
    "SharedToolDefinition",
    "ToolContext",
    "ToolResult",
    "AuthenticatedToolContext",
    "@phake/mcp (core export)",
    "@phake/mcp/runtime/worker",
    "@phake/mcp/runtime/node"
  ]
}
